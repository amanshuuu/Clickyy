<Window x:Class="ClickyWindows.UI.Panel.CompanionPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky Settings"
        Width="360"
        Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border CornerRadius="12"
            Background="#101211"
            BorderBrush="#373B39"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="10"/>
        </Border.Effect>
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,14,16,14" BorderBrush="#373B39" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#60A5FA" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#60A5FA" Opacity="0.6" BlurRadius="4" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Grid.Column="1" Text="Clicky" FontSize="14" FontWeight="SemiBold" Foreground="#ECEEED" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="CloseButton" Width="20" Height="20" Background="Transparent" BorderThickness="0" Click="OnCloseClick">
                        <TextBlock Text="✕" FontSize="10" Foreground="#6B736F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12,16,16">

                <!-- === STATUS === -->
                <TextBlock x:Name="StatusText" Text="Hold your hotkey to talk." FontSize="12" Foreground="#ADB5B2" Margin="0,0,0,12"/>

                <!-- === API KEY === -->
                <TextBlock Text="OpenRouter API Key" FontSize="11" Foreground="#6B736F" Margin="0,0,0,4"/>
                <TextBox x:Name="OpenRouterApiKeyInput" Background="#202221" Foreground="#ECEEED" BorderBrush="#373B39" FontSize="12" Padding="6,4" Margin="0,0,0,12" TextChanged="OnOpenRouterApiKeyChanged"/>

                <!-- === AI MODEL === -->
                <TextBlock Text="AI Model" FontSize="11" Foreground="#6B736F" Margin="0,0,0,4"/>
                <ComboBox x:Name="ModelPicker" Background="#202221" Foreground="#ECEEED" BorderBrush="#373B39" FontSize="12" Margin="0,0,0,12" SelectionChanged="OnModelChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#ECEEED"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- === HOTKEY === -->
                <Border Margin="0,0,0,12" Padding="0,12,0,0" BorderBrush="#373B39" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Push-to-Talk Shortcut" FontSize="11" Foreground="#6B736F" Margin="0,0,0,6"/>
                        <RadioButton x:Name="HotkeyCtrlAlt" GroupName="Hotkey" Content="Ctrl + Alt (Default)" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnHotkeyChanged"/>
                        <RadioButton x:Name="HotkeyCtrlShift" GroupName="Hotkey" Content="Ctrl + Shift" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnHotkeyChanged"/>
                        <RadioButton x:Name="HotkeyAltShift" GroupName="Hotkey" Content="Alt + Shift" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnHotkeyChanged"/>
                        <RadioButton x:Name="HotkeyCtrlAltShift" GroupName="Hotkey" Content="Ctrl + Alt + Shift" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnHotkeyChanged"/>
                    </StackPanel>
                </Border>

                <!-- === TTS === -->
                <Border Margin="0,0,0,12" Padding="0,12,0,0" BorderBrush="#373B39" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Voice (TTS)" FontSize="11" Foreground="#6B736F" Margin="0,0,0,6"/>
                        <ComboBox x:Name="TtsProviderPicker" Background="#202221" Foreground="#ECEEED" BorderBrush="#373B39" FontSize="12" Margin="0,0,0,6" SelectionChanged="OnTtsProviderChanged">
                            <ComboBoxItem Tag="windows" IsSelected="True">Windows TTS (Free - Built-in)</ComboBoxItem>
                            <ComboBoxItem Tag="elevenlabs">ElevenLabs</ComboBoxItem>
                        </ComboBox>
                        <StackPanel x:Name="ElevenLabsPanel" Visibility="Collapsed">
                            <TextBlock Text="ElevenLabs API Key" FontSize="11" Foreground="#6B736F" Margin="0,8,0,4"/>
                            <TextBox x:Name="ElevenLabsApiKeyInput" Background="#202221" Foreground="#ECEEED" BorderBrush="#373B39" FontSize="12" Padding="6,4" Margin="0,0,0,6" TextChanged="OnElevenLabsApiKeyChanged"/>
                            <TextBlock Text="Voice ID" FontSize="11" Foreground="#6B736F" Margin="0,0,0,4"/>
                            <TextBox x:Name="ElevenLabsVoiceIdInput" Background="#202221" Foreground="#ECEEED" BorderBrush="#373B39" FontSize="12" Padding="6,4" Margin="0,0,0,6" TextChanged="OnElevenLabsVoiceIdChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- === BEHAVIOR === -->
                <Border Margin="0,0,0,12" Padding="0,12,0,0" BorderBrush="#373B39" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Behavior" FontSize="11" Foreground="#6B736F" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AudioFeedbackCheck" Content="Play chime on record start/stop" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnAudioFeedbackChanged" Unchecked="OnAudioFeedbackChanged"/>
                        <CheckBox x:Name="TextOnlyModeCheck" Content="Text-only mode (no screen capture)" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnTextOnlyModeChanged" Unchecked="OnTextOnlyModeChanged"/>
                        <CheckBox x:Name="LaunchAtStartupCheck" Content="Launch Clicky when I log in" Foreground="#ECEEED" FontSize="12" Margin="0,0,0,4" Checked="OnLaunchAtStartupChanged" Unchecked="OnLaunchAtStartupChanged"/>
                    </StackPanel>
                </Border>

                <!-- === RECENT INTERACTIONS === -->
                <Border Margin="0,0,0,12" Padding="0,12,0,0" BorderBrush="#373B39" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Recent Interactions" FontSize="11" Foreground="#6B736F" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <Button x:Name="ClearHistoryBtn" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Click="OnClearHistory" Width="Auto">
                                <TextBlock Text="Clear" FontSize="10" Foreground="#6B736F"/>
                            </Button>
                        </Grid>
                        <ItemsControl x:Name="RecentInteractionsList" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#202221" CornerRadius="6" Padding="8,6" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" FontSize="9" Foreground="#6B736F"/>
                                                <TextBlock Text="{Binding WasError, StringFormat='{}⚠️'}" FontSize="9" Foreground="#EF4444" HorizontalAlignment="Right" Visibility="{Binding WasError, Converter={x:Null}}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Transcript}" FontSize="11" Foreground="#ADB5B2" TextWrapping="Wrap" Margin="0,2,0,0" MaxHeight="40"/>
                                            <TextBlock Text="{Binding Response}" FontSize="11" Foreground="#ECEEED" TextWrapping="Wrap" Margin="0,2,0,0" MaxHeight="60"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- === ACTIONS === -->
                <Border Margin="0,0,0,0" Padding="0,12,0,0" BorderBrush="#373B39" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="QuitButton" Click="OnQuitClick"
                                Background="Transparent" Foreground="#ADB5B2" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#202221" CornerRadius="6" Padding="10,6">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="⏻ Quit" FontSize="12"/>
                        </Button>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="WatchOnboardingBtn" Click="OnWatchOnboarding"
                                    Background="Transparent" Foreground="#ADB5B2" FontSize="12" Cursor="Hand" Margin="0,0,6,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#202221" CornerRadius="6" Padding="10,6">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="▶ Onboarding" FontSize="12"/>
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="2" x:Name="SaveButton" Click="OnSaveSettings"
                                Background="Transparent" Foreground="#60A5FA" FontSize="12" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#2563EB" CornerRadius="6" Padding="14,6">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Save" FontSize="12" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
